# ── Groq API ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...your-key-here...

# ── Model Configuration ──────────────────────────────────────────────────────
# Using Groq's high-speed free Llama3 endpoint via OpenAI compatibility
LLM_MODEL=llama3-8b-8192

# Using entirely free local open-source embedding model 
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG Configuration ────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_RESULTS=5

# ── App Configuration ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
