# ── Groq API ─────────────────────────────────────────────────────────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=gsk_...your-key-here...

# ── Model Configuration ───────────────────────────────────────────────────────
# Groq's high-speed Llama3 endpoint (free tier available)
LLM_MODEL=llama3-8b-8192

# Local open-source embedding model — runs on CPU, completely free
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG Configuration ─────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_RESULTS=5

# ── App Configuration ─────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Supabase Config ───────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
# Use the SERVICE ROLE key (not anon) — this stays on the server only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# NOTE: The frontend has ZERO Supabase keys.
# All auth is proxied through the FastAPI backend using the service role key above.
# Never expose the service role key in frontend code or commit it to Git.
